#!/usr/bin/env bash
# lynxsetup — nginx domain management CLI.
#
# Commands:
#   lynxsetup list                                          list all configured domains
#   sudo lynxsetup add <domain> <upstream-ip> <port>        add a reverse-proxy domain
#   sudo lynxsetup add-imgproxy <domain> <upstream-ip> <port>  add an imgproxy caching domain
#   sudo lynxsetup delete <domain>                          remove a domain
#   sudo lynxsetup add-ssh-key "<pubkey>"                   add SSH public key + disable password auth
#
# Usage examples:
#   lynxsetup list
#   sudo lynxsetup add app.client1.com 10.0.0.1 3000
#   sudo lynxsetup add-imgproxy img.example.com 10.0.0.1 8080
#   sudo lynxsetup delete app.client1.com
#   sudo lynxsetup add-ssh-key "ssh-ed25519 AAAA... user@host"

set -euo pipefail

# Resolve real path so this works when called via a symlink (/usr/local/bin/lynxsetup)
SCRIPT="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT")"

TEMPLATE="$SCRIPT_DIR/templates/app.conf.template"
IMGPROXY_TEMPLATE="$SCRIPT_DIR/templates/imgproxy.conf.template"
NGINX_CONF_DIR="/etc/nginx/conf.d"

# ---------------------------------------------------------------------------
# Colors
# ---------------------------------------------------------------------------
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

info()    { echo -e "${CYAN}==>${RESET} $*"; }
success() { echo -e "${GREEN}✓${RESET} $*"; }
warn()    { echo -e "${YELLOW}!${RESET} $*"; }
error()   { echo -e "${RED}ERROR:${RESET} $*" >&2; exit 1; }

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
require_root() {
    [[ $EUID -eq 0 ]] || error "This command requires root. Run: sudo lynxsetup $*"
}

# Convert a domain name to the conf filename we use.
# "www." prefix is stripped; dots become dashes.
domain_to_filename() {
    local domain="${1#www.}"
    echo "${domain//./-}.conf"
}

# ---------------------------------------------------------------------------
# lynxsetup list
# ---------------------------------------------------------------------------
cmd_list() {
    if [[ ! -d "$NGINX_CONF_DIR" ]]; then
        warn "nginx conf.d not found at $NGINX_CONF_DIR — nginx may not be installed yet"
        exit 0
    fi

    shopt -s nullglob
    local files=("$NGINX_CONF_DIR"/*.conf)
    shopt -u nullglob

    if [[ ${#files[@]} -eq 0 ]]; then
        echo "No domains configured yet."
        echo "Add one with: sudo lynxsetup add <domain> <upstream_ip> <port>"
        exit 0
    fi

    printf "${BOLD}%-40s %-20s %-6s  %s${RESET}\n" "DOMAIN" "UPSTREAM" "PORT" "CONFIG FILE"
    printf '%s\n' "$(printf '%.0s─' {1..80})"

    for f in "${files[@]}"; do
        # Extract server_name — skip lines with "default_server"
        local domain
        domain=$(grep -m1 '^\s*server_name ' "$f" 2>/dev/null \
            | grep -v default_server \
            | awk '{print $2}' \
            | tr -d ';') || true
        [[ -z "$domain" ]] && continue

        # Extract upstream address from "server <host>:<port>;" inside an upstream {} block
        local upstream_raw
        upstream_raw=$(grep -m1 '^\s*server [0-9]' "$f" 2>/dev/null \
            | awk '{print $2}' \
            | tr -d ';') || true

        local upstream="${upstream_raw%%:*}"
        local port="${upstream_raw##*:}"

        printf "%-40s %-20s %-6s  %s\n" \
            "$domain" \
            "${upstream:--}" \
            "${port:--}" \
            "$(basename "$f")"
    done
}

# ---------------------------------------------------------------------------
# lynxsetup add <domain> <upstream_ip> <port>
# ---------------------------------------------------------------------------
cmd_add() {
    require_root add "$@"

    if [[ $# -ne 3 ]]; then
        echo "Usage: sudo lynxsetup add <domain> <upstream_ip> <port>"
        echo "  e.g. sudo lynxsetup add app.client1.com 10.0.0.1 3000"
        exit 1
    fi

    local domain="$1" upstream="$2" port="$3"

    # Basic validations
    [[ "$port" =~ ^[0-9]+$ ]]         || error "Port must be a number, got: $port"
    [[ $port -ge 1 && $port -le 65535 ]] || error "Port must be 1–65535, got: $port"

    local app_name="${domain#www.}"
    app_name="${app_name//./-}"
    local app_upstream="app_${app_name//-/_}"
    local out_file="$NGINX_CONF_DIR/${app_name}.conf"

    [[ -f "$out_file" ]] && error "$domain is already configured ($out_file). Delete it first: sudo lynxsetup delete $domain"
    [[ -f "$TEMPLATE" ]] || error "Template not found: $TEMPLATE"

    info "Generating config for $domain → $upstream:$port"

    sed \
        -e "s|__DOMAIN__|${domain}|g" \
        -e "s|__UPSTREAM_IP__|${upstream}|g" \
        -e "s|__PORT__|${port}|g" \
        -e "s|__APP_NAME__|${app_name}|g" \
        -e "s|__APP_UPSTREAM__|${app_upstream}|g" \
        "$TEMPLATE" > "$out_file"

    info "Testing nginx config"
    if ! nginx -t 2>&1; then
        rm -f "$out_file"
        error "nginx config test failed — config removed. Fix the issue and try again."
    fi

    systemctl reload nginx
    success "Domain added: $domain → $upstream:$port"
    echo "  Config: $out_file"
}

# ---------------------------------------------------------------------------
# lynxsetup add-imgproxy <domain> <upstream-ip> <port>
# ---------------------------------------------------------------------------
cmd_add_imgproxy() {
    require_root add-imgproxy "$@"

    if [[ $# -ne 3 ]]; then
        echo "Usage: sudo lynxsetup add-imgproxy <domain> <upstream-ip> <port>"
        echo "  e.g. sudo lynxsetup add-imgproxy img.example.com 10.0.0.1 8080"
        exit 1
    fi

    local domain="$1" upstream="$2" port="$3"

    [[ "$port" =~ ^[0-9]+$ ]]              || error "Port must be a number, got: $port"
    [[ $port -ge 1 && $port -le 65535 ]]   || error "Port must be 1–65535, got: $port"

    local out_file="$NGINX_CONF_DIR/imgproxy.conf"

    [[ -f "$out_file" ]] && error "imgproxy already configured ($out_file). Delete it first: sudo lynxsetup delete $domain"
    [[ -f "$IMGPROXY_TEMPLATE" ]] || error "Template not found: $IMGPROXY_TEMPLATE"

    info "Generating imgproxy config for $domain → $upstream:$port"

    sed \
        -e "s|__IMGPROXY_DOMAIN__|${domain}|g" \
        -e "s|__UPSTREAM_IP__|${upstream}|g" \
        -e "s|__IMGPROXY_PORT__|${port}|g" \
        "$IMGPROXY_TEMPLATE" > "$out_file"

    info "Testing nginx config"
    if ! nginx -t 2>&1; then
        rm -f "$out_file"
        error "nginx config test failed — config removed. Fix the issue and try again."
    fi

    systemctl reload nginx
    success "imgproxy added: $domain → $upstream:$port"
    echo "  Config: $out_file"
}

# ---------------------------------------------------------------------------
# lynxsetup add-ssh-key "<pubkey>"
# ---------------------------------------------------------------------------
cmd_add_ssh_key() {
    require_root add-ssh-key "$@"

    if [[ $# -lt 1 ]]; then
        echo "Usage: sudo lynxsetup add-ssh-key \"<public key>\""
        echo "  e.g. sudo lynxsetup add-ssh-key \"ssh-ed25519 AAAA... user@host\""
        exit 1
    fi

    local pubkey="$*"

    # Basic sanity check — must start with a known key type
    if ! echo "$pubkey" | grep -qE '^(ssh-ed25519|ssh-rsa|ssh-ecdsa|ecdsa-sha2-nistp256|sk-ssh-ed25519) '; then
        error "Doesn't look like a valid SSH public key. Expected format: ssh-ed25519 AAAA... comment"
    fi

    # Determine home dir for the invoking user (SUDO_USER if set, otherwise root)
    local target_user="${SUDO_USER:-root}"
    local home_dir
    home_dir=$(getent passwd "$target_user" | cut -d: -f6)
    local auth_keys="$home_dir/.ssh/authorized_keys"

    mkdir -p "$home_dir/.ssh"
    chmod 700 "$home_dir/.ssh"

    # Avoid duplicate entries
    if grep -qF "$pubkey" "$auth_keys" 2>/dev/null; then
        warn "Key already present in $auth_keys — skipping."
    else
        echo "$pubkey" >> "$auth_keys"
        chmod 600 "$auth_keys"
        chown -R "$target_user:$target_user" "$home_dir/.ssh"
        success "SSH key added to $auth_keys"
    fi

    # Disable password authentication in sshd_config
    local sshd_config="/etc/ssh/sshd_config"
    if grep -qE '^PasswordAuthentication yes' "$sshd_config"; then
        sed -i 's/^PasswordAuthentication yes/PasswordAuthentication no/' "$sshd_config"
        info "PasswordAuthentication set to no"
    elif grep -qE '^#?PasswordAuthentication' "$sshd_config"; then
        sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication no/' "$sshd_config"
        info "PasswordAuthentication set to no"
    else
        echo 'PasswordAuthentication no' >> "$sshd_config"
        info "PasswordAuthentication no added to $sshd_config"
    fi

    # Also enforce in sshd_config.d if Ubuntu drop-in exists
    local dropin="/etc/ssh/sshd_config.d/50-cloud-init.conf"
    if [[ -f "$dropin" ]] && grep -qE 'PasswordAuthentication yes' "$dropin"; then
        sed -i 's/PasswordAuthentication yes/PasswordAuthentication no/' "$dropin"
        info "Patched $dropin"
    fi

    systemctl reload ssh 2>/dev/null || systemctl reload sshd 2>/dev/null || true
    success "Password authentication disabled — key-only login now enforced"
    warn "Make sure you can log in with your key BEFORE closing this session."
}

# ---------------------------------------------------------------------------
# lynxsetup delete <domain>
# ---------------------------------------------------------------------------
cmd_delete() {
    require_root delete "$@"

    if [[ $# -lt 1 ]]; then
        echo "Usage: sudo lynxsetup delete <domain>"
        exit 1
    fi

    local domain="$1"
    local yes=false
    [[ "${2:-}" == "-y" || "${2:-}" == "--yes" ]] && yes=true

    # First try the expected filename
    local filename
    filename=$(domain_to_filename "$domain")
    local conf_file="$NGINX_CONF_DIR/$filename"

    # Fall back: scan all confs for a matching server_name
    if [[ ! -f "$conf_file" ]]; then
        shopt -s nullglob
        local found=""
        for f in "$NGINX_CONF_DIR"/*.conf; do
            if grep -qP "^\s*server_name\s+${domain}\s*;" "$f" 2>/dev/null; then
                found="$f"
                break
            fi
        done
        shopt -u nullglob
        [[ -n "$found" ]] && conf_file="$found"
    fi

    [[ -f "$conf_file" ]] || error "No config found for domain: $domain"

    if [[ "$yes" != true ]]; then
        read -rp "$(echo -e "${YELLOW}Delete${RESET} $domain ($(basename "$conf_file"))? [y/N] ")" ans
        [[ "${ans,,}" == "y" ]] || { echo "Aborted."; exit 0; }
    fi

    rm -f "$conf_file"

    info "Testing nginx config"
    nginx -t

    systemctl reload nginx
    success "Deleted: $domain"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
usage() {
    echo -e "${BOLD}lynxsetup${RESET} — nginx domain manager"
    echo ""
    echo "Usage:"
    echo "  lynxsetup list"
    echo "  sudo lynxsetup add <domain> <upstream-ip> <port>"
    echo "  sudo lynxsetup add-imgproxy <domain> <upstream-ip> <port>"
    echo "  sudo lynxsetup delete <domain> [-y]"
    echo ""
    echo "Examples:"
    echo "  lynxsetup list"
    echo "  sudo lynxsetup add app.client1.com 10.0.0.1 3000"
    echo "  sudo lynxsetup add-imgproxy img.example.com 10.0.0.1 8080"
    echo "  sudo lynxsetup delete app.client1.com"
    echo "  sudo lynxsetup delete app.client1.com -y   # skip confirmation"
    echo "  sudo lynxsetup add-ssh-key \"ssh-ed25519 AAAA... user@host\""
}

case "${1:-}" in
    list)           shift; cmd_list         "$@" ;;
    add)            shift; cmd_add          "$@" ;;
    add-imgproxy)   shift; cmd_add_imgproxy "$@" ;;
    add-ssh-key)    shift; cmd_add_ssh_key  "$@" ;;
    delete)         shift; cmd_delete       "$@" ;;
    -h|--help|help) usage ;;
    *) usage; exit 1 ;;
esac
